<div class="page-header">
    <h2>Admin Dashboard</h2>
    <p>Company-wide expense management overview</p>
</div>

<div class="stats-grid">
    <div class="stats-card">
        <div class="stats-icon">
            <i class="fas fa-building"></i>
        </div>
        <div class="stats-content">
            <div class="stats-value"><%= stats.totalUsers %></div>
            <div class="stats-label">Total Users</div>
        </div>
    </div>
    <div class="stats-card">
        <div class="stats-icon">
            <i class="fas fa-dollar-sign"></i>
        </div>
        <div class="stats-content">
            <div class="stats-value"><%= stats.totalCompanyExpenses %></div>
            <div class="stats-label">Company Expenses</div>
        </div>
    </div>
    <div class="stats-card">
        <div class="stats-icon">
            <i class="fas fa-clock"></i>
        </div>
        <div class="stats-content">
            <div class="stats-value"><%= stats.pendingApprovals %></div>
            <div class="stats-label">Pending Approvals</div>
        </div>
    </div>
    <div class="stats-card">
        <div class="stats-icon">
            <i class="fas fa-chart-line"></i>
        </div>
        <div class="stats-content">
            <div class="stats-value"><%= stats.avgApprovalTime %></div>
            <div class="stats-label">Avg Approval Time</div>
        </div>
    </div>
</div>

<div class="approval-flow">
    <h3>Approval Flow Overview</h3>
    <div class="flow-indicator">
        <div class="flow-step <%= flowSteps.employee.active ? 'active' : '' %>">
            <div class="step-icon">
                <i class="fas fa-user"></i>
            </div>
            <div class="step-label">Employee</div>
            <div class="step-count"><%= flowSteps.employee.count %></div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step <%= flowSteps.manager.active ? 'active' : '' %>">
            <div class="step-icon">
                <i class="fas fa-user-tie"></i>
            </div>
            <div class="step-label">Manager</div>
            <div class="step-count"><%= flowSteps.manager.count %></div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step <%= flowSteps.admin.active ? 'active' : '' %>">
            <div class="step-icon">
                <i class="fas fa-crown"></i>
            </div>
            <div class="step-label">Admin</div>
            <div class="step-count"><%= flowSteps.admin.count %></div>
        </div>
    </div>
</div>